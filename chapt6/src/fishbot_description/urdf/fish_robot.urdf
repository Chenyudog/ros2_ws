<?xml version="1.0"?>
<robot name="first_robot">
    <!--机器人身体部分-->
    <link name="base_link">
        <!--部件的外观描述-->
        <visual>
        <!--沿着自己的几何中心点的平移和旋转-->
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
            <!--圆柱体-->
                <cylinder radius="0.1" length="0.12"/>
            </geometry>   
            <material name="white">
                <color rgba="1.0 0.0 1.0 0.5" />
            </material>
        </visual>
    </link>


    <!--机器人的IMU部件-->
    <link name="IMU">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>

            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>

            <material name="black">
                <color rgba="1.0 0.0 0.0 0.5"/>
            </material>

        </visual>
    </link>
    <!--机器人的关节-->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="IMU"/>
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>                
    </joint>
</robot>